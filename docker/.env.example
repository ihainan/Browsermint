# Browsermint Production Environment
# Copy this file to .env and fill in the values before deploying.

# Build configuration
BUILD_CONTEXT=..
BACKEND_DOCKERFILE=docker/Dockerfile.backend
FRONTEND_DOCKERFILE=docker/Dockerfile.frontend

# Docker Compose project name
COMPOSE_PROJECT_NAME=browsermint

# Docker network name (must match DOCKER_NETWORK_NAME passed to backend)
DOCKER_NETWORK_NAME=browsermint-internal

# Nginx external port
NGINX_PORT=24700

# PostgreSQL
POSTGRES_USER=browsermint
POSTGRES_PASSWORD=        # required: set a strong password
POSTGRES_DB=browsermint
POSTGRES_DATA_DIR=        # required: absolute path on host for postgres data (e.g. /opt/browsermint/postgres)

# Backend secrets — must be random strings of at least 32 characters
JWT_SECRET=               # required: generate with: openssl rand -hex 32
JWT_SESSION_TOKEN_SECRET= # required: generate with: openssl rand -hex 32

# Steel Browser image
STEEL_BROWSER_IMAGE=ihainan/browsermint-browser:0.5.1

# Default session limit for new users (0 = unlimited, admins always get 0)
DEFAULT_USER_MAX_SESSIONS=2

# Auto captcha solving via CapSolver (optional). Leave empty to disable.
# Get your API key at https://capsolver.com
CAPSOLVER_API_KEY=

# User registration: "open" (anyone can register) or "disabled" (admin-only account creation)
REGISTRATION_MODE=open

# Idle auto-pause: pause sessions with no active connections after this timeout
IDLE_PAUSE_ENABLED=true
IDLE_PAUSE_TIMEOUT_MS=600000

# Session WebSocket token expiry (e.g. "180d", "30d")
SESSION_TOKEN_EXPIRY=180d
