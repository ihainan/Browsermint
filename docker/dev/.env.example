# SteelYard PostgreSQL Development Environment
# Copy to .env and adjust for your local setup

# Docker Compose project configuration
COMPOSE_PROJECT_NAME=steelyard-dev
POSTGRES_CONTAINER_NAME=steelyard-postgres-dev

# PostgreSQL credentials
POSTGRES_USER=steelyard
POSTGRES_PASSWORD=steelyard_dev_2026
POSTGRES_DB=steelyard

# Port mapping (host:container)
POSTGRES_PORT=24720

