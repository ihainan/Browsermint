# Browsermint PostgreSQL Development Environment
# Copy to .env and adjust for your local setup

# Docker Compose project configuration
COMPOSE_PROJECT_NAME=browsermint-dev
POSTGRES_CONTAINER_NAME=browsermint-postgres-dev

# PostgreSQL credentials
POSTGRES_USER=browsermint
POSTGRES_PASSWORD=browsermint_dev_2026
POSTGRES_DB=browsermint

# Port mapping (host:container)
POSTGRES_PORT=24720

